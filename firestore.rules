rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entities ---

    // Logs Collection
    match /logs/{logId} {
      function isValidLog(data) {
        return data.keys().hasAll(['query', 'consensus', 'timestamp', 'userId', 'confidence']) &&
               data.keys().size() == 5 &&
               data.query is string && data.query.size() <= 1000 &&
               data.consensus is string && data.consensus.size() <= 10000 &&
               data.timestamp == request.time &&
               data.userId == request.auth.uid &&
               data.confidence is number && data.confidence >= 0 && data.confidence <= 1;
      }

      allow create: if isSignedIn() && isEmailVerified() && isValidId(logId) && isValidLog(incoming());
      // Global Pulse requires public readability of interactions
      allow read: if true; 
      // Logs are immutable for integrity
      allow update: if false; 
      allow delete: if isOwner(existing().userId);
    }

    // Archives Collection
    match /archives/{archiveId} {
      function isValidArchive(data) {
        return data.keys().hasAll(['title', 'content', 'publicationDate']) &&
               data.title is string && data.title.size() <= 200 &&
               data.content is string && data.content.size() <= 50000;
      }

      allow read: if true; // Public records
      // System-only writes - For now, we deny client writes to maintain integrity
      allow write: if false; 
    }
  }
}
